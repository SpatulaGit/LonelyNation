{
	"schemaVersion": 1,
	"id": "lonely-nation",
	"version": "${version}",
	"name": "Lonely Nation",
	"description": "A Minecraft mod for simulating different government systems with villagers.",
	"authors": [
		"Spatula_Rat"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/SpatulaGit/LonelyNation"
	},
	"license": "CC0-1.0",
	"icon": "assets/lonely-nation/icon.png",
	"environment": "client",
	"entrypoints": {
		"main": [
			"spatularat.lonelynation.LonelyNation"
		],
		"client": [
			"spatularat.lonelynation.client.LonelyNationClient"
		]
	},
	"mixins": [
		"lonely-nation.mixins.json",
